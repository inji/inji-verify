{
  "allChecksSuccessful": {{allChecksSuccessful}},
  "schemaAndSignatureCheck": {
    "valid": {{schemaAndSignatureCheck.valid}},
    "error": {{#if schemaAndSignatureCheck.error}}
    {
      "errorCode": "{{schemaAndSignatureCheck.error.errorCode}}"
      }
      {{else}}
      null
      {{/if}}
  },
  "expiryCheck": {{#if expiryCheck}}
    {
    "valid": {{expiryCheck.valid}}
    }
    {{else}}
    null
    {{/if}},
  "statusCheck": [
    {{#each statusCheck}}
      {
      "purpose": "{{purpose}}",
      "valid": {{valid}},
      "error": {{#if error}}
      {
        "errorCode": "{{error.errorCode}}"
      }
      {{else}}
      	null
      {{/if}}
  }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "claims": {
    {{#each claims}}
      "{{@key}}": "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  }
}
