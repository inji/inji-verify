<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>io.inji.verify</groupId>
  <artifactId>uitest-injiverify</artifactId>
  <name>inji-ui-verify</name>
  <version>0.16.0</version>
  <description>Parent project of ui automation of inji-verify</description>
  <url>https://github.com/inji/inji-verify</url>
  <developers>
    <developer>
      <name>Mosip</name>
      <email>mosip.emailnotifier@gmail.com</email>
      <organization>io.inji</organization>
      <organizationUrl>https://github.com/inji/inji-verify</organizationUrl>
    </developer>
  </developers>
  <licenses>
    <license>
      <name>MPL 2.0</name>
      <url>https://www.mozilla.org/en-US/MPL/2.0/</url>
    </license>
  </licenses>
  <build>
    <testResources>
      <testResource>
        <directory>src/test/resources</directory>
        <includes>
          <include>**/*</include>
        </includes>
      </testResource>
    </testResources>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.10.1</version>
        <configuration>
          <source>21</source>
          <target>21</target>
        </configuration>
      </plugin>
      <plugin>
        <groupId>pl.project13.maven</groupId>
        <artifactId>git-commit-id-plugin</artifactId>
        <version>3.0.1</version>
        <configuration>
          <dotGitDirectory>${project.basedir}/.git</dotGitDirectory>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-gpg-plugin</artifactId>
        <version>1.5</version>
        <executions>
          <execution>
            <id>sign-artifacts</id>
            <phase>verify</phase>
            <goals>
              <goal>sign</goal>
            </goals>
            <configuration>
              <gpgArguments>
                <arg>--pinentry-mode</arg>
                <arg>loopback</arg>
              </gpgArguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${surefire.plugin.version}</version>
        <configuration>
          <skipTests>true</skipTests>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>${maven.shade.plugin.version}</version>
        <executions>
          <execution>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>${fileName}</finalName>
              <transformers>
                <transformer />
                <transformer>
                  <mainClass>runnerfiles.Runner</mainClass>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <extentreports.adapter.version>1.13.0</extentreports.adapter.version>
    <pdfbox.version>2.0.31</pdfbox.version>
    <cucumber.picocontainer.version>7.14.0</cucumber.picocontainer.version>
    <browserstack.local.version>1.1.5</browserstack.local.version>
    <maven.compiler.source>1.8</maven.compiler.source>
    <cucumber.junit.version>7.17.0</cucumber.junit.version>
    <commons.lang.version>2.6</commons.lang.version>
    <surefire.plugin.version>3.0.0-M5</surefire.plugin.version>
    <cucumber.testng.version>7.2.3</cucumber.testng.version>
    <jackson.version>2.15.2</jackson.version>
    <aws.sdk.s3.version>1.12.794</aws.sdk.s3.version>
    <json.simple.version>1.1.1</json.simple.version>
    <maven.shade.plugin.version>3.2.4</maven.shade.plugin.version>
    <browserstack.sdk.version>1.31.1</browserstack.sdk.version>
    <maven.compiler.target>1.8</maven.compiler.target>
    <selenium.version>4.17.0</selenium.version>
    <slf4j.version>2.0.9</slf4j.version>
    <cucumber.version>7.2.3</cucumber.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <extentreports.version>5.1.0</extentreports.version>
    <gherkin.version>22.0.0</gherkin.version>
  </properties>
</project>
