    {
      "logo": "/assets/cert.png",
      "name": "Mock Identity (SD JWT)",
      "type": "SD_JWT",
      "clientIdScheme":"decentralized_identifier",
      "definition": {
        "purpose": "Relying party is requesting your digital ID for the purpose of Self-Authentication",
        "format": {
          "vc+sd-jwt": {
            "sd-jwt_alg_values": ["EdDSA"]
          }
        },
        "input_descriptors": [
          {
            "id": "Mock Identity card credential",
            "format": {
              "vc+sd-jwt": {
                "sd-jwt_alg_values": ["EdDSA"]
              }
            },
            "constraints": {
              "fields": [
                {
                  "path": ["$.vct"],
                  "filter": {
                    "type": "string",
                    "pattern": "SD_JWT"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
