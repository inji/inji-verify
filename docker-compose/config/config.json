{
  "verifiableClaims": [
    {
      "logo": "/assets/cert.png",
      "name": "MOSIP ID",
      "type": "MOSIPVerifiableCredential",
      "essential": true,
      "clientIdScheme":"decentralized_identifier",
      "definition": {
        "purpose": "Relying party is requesting your digital ID for the purpose of Self-Authentication",
        "format": {
          "ldp_vc": {
            "proof_type": [
              "RsaSignature2018",
              "Ed25519Signature2020"
            ]
          }
        },
        "input_descriptors": [
          {
            "id": "id card credential",
            "format": {
              "ldp_vc": {
                "proof_type": [
                  "RsaSignature2018",
                  "Ed25519Signature2020"
                ]
              }
            },
            "constraints": {
              "fields": [
                {
                  "path": ["$.type"],
                  "filter": {
                    "type": "object",
                    "pattern": "MOSIPVerifiableCredential"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "logo": "/assets/cert.png",
